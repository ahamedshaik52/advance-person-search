```csharp
using System;
using System.Collections.Generic;
using System.Text;
using ALPT2635.Plugins.Helpers;
using Microsoft.Xrm.Sdk;
using Microsoft.Xrm.Sdk.Query;

namespace ALPT2635.Plugins
{
    /// <summary>
    /// Registered on Custom API: cw_AdvancedPersonSearch
    /// Stage: Pre-operation (20), Synchronous
    /// NO Azure AD App Registration required — uses IOrganizationService only.
    /// Fuzzy search: QueryExpression Contains + pre-computed Soundex columns.
    /// </summary>
    public sealed class AdvancedPersonSearchPlugin : IPlugin
    {
        // ── Verify ALL logical names match YOUR environment ──────────────────
        // Table names
        private const string TblContact  = "cw_contact";
        private const string TblPhone    = "cw_phonenumber";
        private const string TblAddress  = "cw_personaddress";   // verify this name

        // cw_contact columns
        private const string ColContactId    = "cw_contactid";   // primary key — usually tablename + "id"
        private const string ColFirstName    = "cw_firstname";
        private const string ColLastName     = "cw_lastname";
        private const string ColDob          = "cw_dateofbirth";
        private const string ColSsn          = "cw_ssn";
        private const string ColSex          = "cw_sex";
        private const string ColRace         = "cw_race";
        private const string ColSoundexFirst = "cw_soundexfirstname";
        private const string ColSoundexLast  = "cw_soundexlastname";

        // cw_phonenumber columns
        private const string ColPhonePersonRef = "cw_contactid";  // lookup column to cw_contact
        private const string ColPhoneNumber    = "cw_phonenumber";

        // cw_personaddress columns
        private const string ColAddrPersonRef  = "cw_contactid";  // lookup column to cw_contact
        private const string ColAddrLine1      = "cw_addressline1";
        private const string ColAddrLine2      = "cw_addressline2";
        private const string ColAddrCity       = "cw_city";
        private const string ColAddrState      = "cw_state";
        private const string ColAddrZip        = "cw_zipcode";
        private const string ColAddrCounty     = "cw_county";

        private const int MaxResults        = 200;
        private const int InClauseBatchSize = 100;  // BUG FIX #6

        // Constructor — no config needed (no OAuth)
        public AdvancedPersonSearchPlugin() { }
        public AdvancedPersonSearchPlugin(string unsecureConfig, string secureConfig) { }

        public void Execute(IServiceProvider serviceProvider)
        {
            var context = (IPluginExecutionContext)
                serviceProvider.GetService(typeof(IPluginExecutionContext));
            var factory = (IOrganizationServiceFactory)
                serviceProvider.GetService(typeof(IOrganizationServiceFactory));
            var svc = factory.CreateOrganizationService(context.UserId);

            try
            {
                var p = ExtractParameters(context);
                var results = p.IsExactMatch
                    ? RunExactSearch(svc, p)
                    : RunFuzzySearch(svc, p);

                var response = new SearchApiResponse
                {
                    Success    = true,
                    Results    = results,
                    TotalCount = results.Count
                };

                context.OutputParameters["cw_searchresults"] = response.ToJson();
                context.OutputParameters["cw_success"]       = true;
                context.OutputParameters["cw_errormessage"]  = string.Empty;
            }
            catch (InvalidPluginExecutionException) { throw; }
            catch (Exception ex)
            {
                var errResp = SearchApiResponse.Error($"Search error: {ex.Message}");
                context.OutputParameters["cw_searchresults"] = errResp.ToJson();
                context.OutputParameters["cw_success"]       = false;
                context.OutputParameters["cw_errormessage"]  = ex.Message;
            }
        }

        // ═════════════════════════════════════════════════════════════════════
        // PATH A — EXACT SEARCH
        // ═════════════════════════════════════════════════════════════════════
        private List<PersonSearchResult> RunExactSearch(IOrganizationService svc,
                                                         SearchInputParameters p)
        {
            var qe = BuildBaseQuery();

            // Name — exact equal
            if (!string.IsNullOrWhiteSpace(p.FirstName))
                qe.Criteria.AddCondition(ColFirstName, ConditionOperator.Equal,
                    p.FirstName.Trim());
            if (!string.IsNullOrWhiteSpace(p.LastName))
                qe.Criteria.AddCondition(ColLastName, ConditionOperator.Equal,
                    p.LastName.Trim());

            ApplySharedFilters(qe, p);
            AddPhoneJoin(qe, p);
            AddAddressJoin(qe, p);

            return HydrateResults(svc, svc.RetrieveMultiple(qe).Entities);
        }

        // ═════════════════════════════════════════════════════════════════════
        // PATH B — FUZZY + PHONETIC SEARCH (no HTTP, no Azure AD)
        // AC2: Contains search handles partial/typo matching
        // AC3: Soundex search handles phonetic matching
        // ═════════════════════════════════════════════════════════════════════
        private List<PersonSearchResult> RunFuzzySearch(IOrganizationService svc,
                                                         SearchInputParameters p)
        {
            var allGuids = new HashSet<Guid>();
            bool hasNameInput = !string.IsNullOrWhiteSpace(p.FirstName)
                             || !string.IsNullOrWhiteSpace(p.LastName);

            if (hasNameInput)
            {
                // B1: Contains search — catches partial matches and common typos
                allGuids.UnionWith(ExecuteContainsSearch(svc, p));

                // B2: Soundex phonetic search — catches phonetic variants
                allGuids.UnionWith(ExecuteSoundexSearch(svc, p));
            }

            // If no name provided or no candidates found, fall back to exact path
            if (allGuids.Count == 0)
                return RunExactSearch(svc, p);

            // Apply all non-name filters on the merged candidate set
            return ApplyPostFilters(svc, allGuids, p);
        }

        // ─── B1: Contains search ─────────────────────────────────────────────
        private List<Guid> ExecuteContainsSearch(IOrganizationService svc,
                                                  SearchInputParameters p)
        {
            var guids = new List<Guid>();
            var qe    = new QueryExpression(TblContact)
            {
                ColumnSet = new ColumnSet(false),  // ID only
                TopCount  = MaxResults,
                NoLock    = true
            };

            // Use OR filter — match if either name contains the input
            var nameFilter = new FilterExpression(LogicalOperator.Or);
            if (!string.IsNullOrWhiteSpace(p.FirstName))
                nameFilter.AddCondition(ColFirstName, ConditionOperator.Contains,
                    p.FirstName.Trim());
            if (!string.IsNullOrWhiteSpace(p.LastName))
                nameFilter.AddCondition(ColLastName, ConditionOperator.Contains,
                    p.LastName.Trim());

            qe.Criteria.AddFilter(nameFilter);

            foreach (var e in svc.RetrieveMultiple(qe).Entities)
                guids.Add(e.Id);
            return guids;
        }

        // ─── B2: Soundex phonetic search ─────────────────────────────────────
        private List<Guid> ExecuteSoundexSearch(IOrganizationService svc,
                                                 SearchInputParameters p)
        {
            var guids = new List<Guid>();
            var qe    = new QueryExpression(TblContact)
            {
                ColumnSet = new ColumnSet(false),
                TopCount  = MaxResults,
                NoLock    = true
            };

            bool hasFilter = false;

            if (!string.IsNullOrWhiteSpace(p.FirstName))
            {
                qe.Criteria.AddCondition(ColSoundexFirst, ConditionOperator.Equal,
                    SoundexHelper.Compute(p.FirstName.Trim()));
                hasFilter = true;
            }
            if (!string.IsNullOrWhiteSpace(p.LastName))
            {
                qe.Criteria.AddCondition(ColSoundexLast, ConditionOperator.Equal,
                    SoundexHelper.Compute(p.LastName.Trim()));
                hasFilter = true;
            }

            if (!hasFilter) return guids;

            foreach (var e in svc.RetrieveMultiple(qe).Entities)
                guids.Add(e.Id);
            return guids;
        }

        // ─── Post-filter merged candidate GUIDs ──────────────────────────────
        private List<PersonSearchResult> ApplyPostFilters(IOrganizationService svc,
                                                           HashSet<Guid> candidateGuids,
                                                           SearchInputParameters p)
        {
            var allEntities = new List<Entity>();
            var guidList    = new List<Guid>(candidateGuids);

            // BUG FIX #6: batch 100 GUIDs per IN clause
            for (int i = 0; i < guidList.Count; i += InClauseBatchSize)
            {
                var batch      = guidList.GetRange(i,
                    Math.Min(InClauseBatchSize, guidList.Count - i));
                var batchArray = batch.ConvertAll(g => (object)g).ToArray();

                var qe = BuildBaseQuery();
                qe.Criteria.AddCondition(TblContact + "id",
                    ConditionOperator.In, batchArray);

                ApplySharedFilters(qe, p);
                AddPhoneJoin(qe, p);
                AddAddressJoin(qe, p);

                allEntities.AddRange(svc.RetrieveMultiple(qe).Entities);
            }

            return HydrateResults(svc, allEntities);
        }

        // ═════════════════════════════════════════════════════════════════════
        // SHARED FILTER HELPERS
        // ═════════════════════════════════════════════════════════════════════

        /// <summary>Applies SSN, Gender, Race, DOB filters.</summary>
        private static void ApplySharedFilters(QueryExpression qe, SearchInputParameters p)
        {
            // Person ID
            if (!string.IsNullOrWhiteSpace(p.PersonId)
                && int.TryParse(p.PersonId, out var pidInt))
                qe.Criteria.AddCondition("cw_personid", ConditionOperator.Equal, pidInt);

            // SSN — last 4 or full 9
            if (!string.IsNullOrWhiteSpace(p.Ssn))
            {
                if (p.Ssn.Length == 4)
                    qe.Criteria.AddCondition(ColSsn, ConditionOperator.EndsWith, p.Ssn);
                else
                    qe.Criteria.AddCondition(ColSsn, ConditionOperator.Equal, p.Ssn);
            }

            // Gender (option set integer)
            if (!string.IsNullOrWhiteSpace(p.Gender)
                && int.TryParse(p.Gender, out var gCode))
                qe.Criteria.AddCondition(ColSex, ConditionOperator.Equal, gCode);

            // Race (multi-value option set)
            if (!string.IsNullOrWhiteSpace(p.RaceValues))
            {
                var raceCodes = ParseIntList(p.RaceValues);
                if (raceCodes.Count > 0)
                    qe.Criteria.AddCondition(ColRace,
                        ConditionOperator.ContainValues, raceCodes.ToArray());
            }

            // DOB range — BUG FIX #8: UTC
            if (!string.IsNullOrWhiteSpace(p.Dob) && TryParseDob(p.Dob, out var dob))
            {
                var dobUtc = DateTime.SpecifyKind(dob, DateTimeKind.Utc);
                qe.Criteria.AddCondition(ColDob, ConditionOperator.GreaterEqual, dobUtc.Date);
                qe.Criteria.AddCondition(ColDob, ConditionOperator.LessEqual,
                    dobUtc.Date.AddDays(1).AddTicks(-1));
            }
        }

        private void AddPhoneJoin(QueryExpression qe, SearchInputParameters p)
        {
            if (string.IsNullOrWhiteSpace(p.PhoneNumber)) return;
            var lnk = qe.AddLink(TblPhone, TblContact + "id",
                ColPhonePersonRef, JoinOperator.Inner);
            lnk.LinkCriteria.AddCondition(ColPhoneNumber,
                ConditionOperator.Equal, p.PhoneNumber);
        }

        private void AddAddressJoin(QueryExpression qe, SearchInputParameters p)
        {
            bool hasAddr = !string.IsNullOrWhiteSpace(p.AddressLine1)
                        || !string.IsNullOrWhiteSpace(p.AddressLine2)
                        || !string.IsNullOrWhiteSpace(p.City)
                        || !string.IsNullOrWhiteSpace(p.State)
                        || !string.IsNullOrWhiteSpace(p.ZipCode)
                        || !string.IsNullOrWhiteSpace(p.County);
            if (!hasAddr) return;

            var lnk = qe.AddLink(TblAddress, TblContact + "id",
                ColAddrPersonRef, JoinOperator.Inner);

            if (!string.IsNullOrWhiteSpace(p.AddressLine1))
                lnk.LinkCriteria.AddCondition(ColAddrLine1,
                    ConditionOperator.Contains, p.AddressLine1);
            if (!string.IsNullOrWhiteSpace(p.AddressLine2))
                lnk.LinkCriteria.AddCondition(ColAddrLine2,
                    ConditionOperator.Contains, p.AddressLine2);
            if (!string.IsNullOrWhiteSpace(p.City))
                lnk.LinkCriteria.AddCondition(ColAddrCity,
                    ConditionOperator.Equal, p.City);
            if (!string.IsNullOrWhiteSpace(p.State))
                lnk.LinkCriteria.AddCondition(ColAddrState,
                    ConditionOperator.Equal, p.State.ToUpperInvariant());
            if (!string.IsNullOrWhiteSpace(p.ZipCode))
                lnk.LinkCriteria.AddCondition(ColAddrZip,
                    ConditionOperator.Equal, p.ZipCode);
            if (!string.IsNullOrWhiteSpace(p.County))
                lnk.LinkCriteria.AddCondition(ColAddrCounty,
                    ConditionOperator.Contains, p.County);
        }

        // ═════════════════════════════════════════════════════════════════════
        // HYDRATE — build flat result list
        // ═════════════════════════════════════════════════════════════════════
        private List<PersonSearchResult> HydrateResults(IOrganizationService svc,
                                                          IEnumerable<Entity> contacts)
        {
            var results = new List<PersonSearchResult>();
            var seen    = new HashSet<Guid>();

            foreach (var contact in contacts)
            {
                if (!seen.Add(contact.Id)) continue;

                // Address lookup
                var addrQe = new QueryExpression(TblAddress)
                {
                    ColumnSet = new ColumnSet(ColAddrLine1, ColAddrLine2,
                                              ColAddrCity,  ColAddrState,
                                              ColAddrZip,   ColAddrCounty),
                    TopCount  = 1,
                    NoLock    = true
                };
                addrQe.Criteria.AddCondition(ColAddrPersonRef,
                    ConditionOperator.Equal, contact.Id);
                var addrs = svc.RetrieveMultiple(addrQe).Entities;

                string fullAddress = null;
                if (addrs.Count > 0)
                {
                    var a  = addrs[0];
                    var sb = new StringBuilder();
                    AppendPart(sb, a, ColAddrLine1);
                    AppendPart(sb, a, ColAddrLine2);
                    AppendPart(sb, a, ColAddrCity);
                    AppendPart(sb, a, ColAddrState);
                    AppendPart(sb, a, ColAddrZip);
                    fullAddress = sb.ToString().TrimEnd(',', ' ');
                }

                // DOB
                string dobStr = null;
                if (contact.Contains(ColDob))
                    dobStr = contact.GetAttributeValue<DateTime>(ColDob)
                                    .ToLocalTime()
                                    .ToString("MM/dd/yyyy");

                // Sex label
                string sexLabel = null;
                if (contact.Contains(ColSex))
                {
                    var osv = contact.GetAttributeValue<OptionSetValue>(ColSex);
                    if (osv != null)
                        sexLabel = osv.Value == 471560000 ? "Male"
                                 : osv.Value == 471560001 ? "Female"
                                 : osv.Value == 471560002 ? "Unknown"
                                 : osv.Value.ToString();
                }

                var fn = contact.GetAttributeValue<string>(ColFirstName)  ?? "";
                var ln = contact.GetAttributeValue<string>(ColLastName)   ?? "";

                results.Add(new PersonSearchResult
                {
                    PersonId    = contact.Id.ToString(),
                    DisplayName = $"{fn} {ln}".Trim(),
                    Dob         = dobStr,
                    SexLabel    = sexLabel,
                    FullAddress = fullAddress
                });
            }
            return results;
        }

        private static void AppendPart(StringBuilder sb, Entity e, string col)
        {
            var v = e.GetAttributeValue<string>(col);
            if (!string.IsNullOrWhiteSpace(v))
            {
                if (sb.Length > 0) sb.Append(", ");
                sb.Append(v.Trim());
            }
        }

        // ═════════════════════════════════════════════════════════════════════
        // UTILITY HELPERS
        // ═════════════════════════════════════════════════════════════════════
        private QueryExpression BuildBaseQuery() =>
            new QueryExpression(TblContact)
            {
                ColumnSet = new ColumnSet(ColFirstName, ColLastName, ColDob,
                                          ColSsn, ColSex, ColRace),
                TopCount  = MaxResults,
                NoLock    = true
            };

        private static SearchInputParameters ExtractParameters(IPluginExecutionContext ctx)
        {
            T Get<T>(string key) =>
                ctx.InputParameters.Contains(key) ? (T)ctx.InputParameters[key] : default;

            return new SearchInputParameters
            {
                FirstName    = Get<string>("cw_firstname"),
                LastName     = Get<string>("cw_lastname"),
                Dob          = Get<string>("cw_dob"),
                PersonId     = Get<string>("cw_personid"),
                Ssn          = Get<string>("cw_ssn"),
                PhoneNumber  = Get<string>("cw_phonenumber"),
                AddressLine1 = Get<string>("cw_addressline1"),
                AddressLine2 = Get<string>("cw_addressline2"),
                City         = Get<string>("cw_city"),
                State        = Get<string>("cw_state"),
                ZipCode      = Get<string>("cw_zipcode"),
                County       = Get<string>("cw_county"),
                Gender       = Get<string>("cw_gender"),
                RaceValues   = Get<string>("cw_racevalues"),
                IsExactMatch = Get<bool>("cw_isexactmatch")
            };
        }

        private static bool TryParseDob(string raw, out DateTime result)
        {
            result = default;
            string[] fmts = { "MM/dd/yyyy", "M/d/yyyy", "yyyy-MM-dd" };
            return DateTime.TryParseExact(raw.Trim(), fmts,
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None, out result);
        }

        private static List<int> ParseIntList(string csv)
        {
            var list = new List<int>();
            if (string.IsNullOrWhiteSpace(csv)) return list;
            foreach (var part in csv.Split(','))
                if (int.TryParse(part.Trim(), out var v)) list.Add(v);
            return list;
        }
    }
}
