using System.Text;

namespace ALPT2635.Plugins.Helpers
{
    /// <summary>
    /// US Russell Soundex. Returns exactly 4 characters.
    /// John→J500, Jhon→J500, Smith→S530, Smyth→S530, Fisher→F260, Fischer→F260
    /// </summary>
    internal static class SoundexHelper
    {
        private static readonly char[] _codeMap = new char[26];

        static SoundexHelper()
        {
            for (int i = 0; i < 26; i++) _codeMap[i] = '0';
            foreach (char c in "BFPV")     _codeMap[c - 'A'] = '1';
            foreach (char c in "CGJKQSXZ") _codeMap[c - 'A'] = '2';
            foreach (char c in "DT")       _codeMap[c - 'A'] = '3';
            _codeMap['L' - 'A'] = '4';
            foreach (char c in "MN")       _codeMap[c - 'A'] = '5';
            _codeMap['R' - 'A'] = '6';
        }

        public static string Compute(string input)
        {
            if (string.IsNullOrWhiteSpace(input)) return "0000";

            var sb = new StringBuilder();
            foreach (char c in input)
                if (char.IsLetter(c)) sb.Append(char.ToUpperInvariant(c));

            if (sb.Length == 0) return "0000";

            string letters  = sb.ToString();
            char   first    = letters[0];
            var    result   = new StringBuilder();
            result.Append(first);
            char prevCode = GetCode(first);

            for (int i = 1; i < letters.Length && result.Length < 4; i++)
            {
                char ch   = letters[i];
                char code = GetCode(ch);
                if (ch == 'H' || ch == 'W') continue;
                if (code == '0') { prevCode = '0'; continue; }
                if (code != prevCode) { result.Append(code); prevCode = code; }
            }

            while (result.Length < 4) result.Append('0');
            return result.ToString();
        }

        private static char GetCode(char c)
        {
            int idx = c - 'A';
            return (idx >= 0 && idx < 26) ? _codeMap[idx] : '0';
        }
    }
}
