using ALPT2635.Plugins.Helpers;
using Microsoft.Xrm.Sdk;

namespace ALPT2635.Plugins
{
    /// <summary>
    /// Registered: Post-operation, Async (Stage 40) on cw_contact Create + Update.
    /// Pre-Image "PreImage" required on Update step.
    /// Filtering Attributes on Update step: cw_firstname, cw_lastname
    /// Does NOT require Azure AD — uses IOrganizationService only.
    /// </summary>
    public sealed class PersonSoundexPlugin : IPlugin
    {
        // ── Verify these logical names match YOUR cw_contact table ───────────
        private const string TblContact      = "cw_contact";
        private const string ColFirstName    = "cw_firstname";
        private const string ColLastName     = "cw_lastname";
        private const string ColSoundexFirst = "cw_soundexfirstname";  // lowercase
        private const string ColSoundexLast  = "cw_soundexlastname";   // lowercase

        public void Execute(IServiceProvider serviceProvider)
        {
            var context = (IPluginExecutionContext)
                serviceProvider.GetService(typeof(IPluginExecutionContext));

            if (context.Depth > 2) return;

            var factory = (IOrganizationServiceFactory)
                serviceProvider.GetService(typeof(IOrganizationServiceFactory));
            var svc = factory.CreateOrganizationService(context.UserId);

            var target = (Entity)context.InputParameters["Target"];

            string firstName, lastName;

            if (context.MessageName == "Create")
            {
                firstName = target.GetAttributeValue<string>(ColFirstName);
                lastName  = target.GetAttributeValue<string>(ColLastName);
            }
            else if (context.MessageName == "Update")
            {
                Entity preImage = context.PreEntityImages.Contains("PreImage")
                    ? context.PreEntityImages["PreImage"] : null;

                firstName = target.Contains(ColFirstName)
                    ? target.GetAttributeValue<string>(ColFirstName)
                    : preImage?.GetAttributeValue<string>(ColFirstName);

                lastName = target.Contains(ColLastName)
                    ? target.GetAttributeValue<string>(ColLastName)
                    : preImage?.GetAttributeValue<string>(ColLastName);

                // Infinite-loop guard: skip if Soundex unchanged
                var currentSdxFirst = preImage?.GetAttributeValue<string>(ColSoundexFirst);
                var currentSdxLast  = preImage?.GetAttributeValue<string>(ColSoundexLast);
                var newSdxFirst     = SoundexHelper.Compute(firstName);
                var newSdxLast      = SoundexHelper.Compute(lastName);

                if (newSdxFirst == currentSdxFirst && newSdxLast == currentSdxLast)
                    return;
            }
            else
            {
                return;
            }

            var update = new Entity(TblContact, target.Id);
            update[ColSoundexFirst] = SoundexHelper.Compute(firstName);
            update[ColSoundexLast]  = SoundexHelper.Compute(lastName);
            svc.Update(update);
        }
    }
}
