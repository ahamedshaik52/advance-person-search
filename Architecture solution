@{if(triggerBody()?['IsExactMatch'], 
  concat(
    if(not(empty(triggerBody()?['FirstName'])), concat('cw_firstname eq ''', triggerBody()?['FirstName'],''' and '),''),
    if(not(empty(triggerBody()?['LastName'])), concat('cw_lastname eq ''', triggerBody()?['LastName'],''' and '),''),
